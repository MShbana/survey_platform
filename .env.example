SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_ENGINE=django.db.backends.postgresql
POSTGRES_DB=survey_builder
POSTGRES_USER=survey_user
POSTGRES_PASSWORD=survey_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgres://survey_user:survey_pass@db:5432/survey_builder

# Timezones
TZ=UTC
PGTZ=UTC
DJANGO_TIME_ZONE=UTC
CELERY_TIMEZONE=UTC

# Redis
REDIS_PASSWORD=change-me-to-a-strong-password
REDIS_URL=redis://:change-me-to-a-strong-password@redis:6379/0
CACHE_BACKEND=django_redis.cache.RedisCache

# Celery
CELERY_BROKER_URL=redis://:change-me-to-a-strong-password@redis:6379/1
CELERY_RESULT_BACKEND=redis://:change-me-to-a-strong-password@redis:6379/2

# Encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# JWT (used as SIGNING_KEY; falls back to SECRET_KEY if not set)
JWT_SECRET_KEY=

# CORS (set to specific origins in production, e.g., https://yourdomain.com)
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Default admin (only created if no admin user exists)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-to-a-strong-password
